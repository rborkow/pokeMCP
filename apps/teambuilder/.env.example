# PokéMCP Team Builder Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Required for AI Chat Feature
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================
# Optional Configuration
# ============================================
# MCP API URL (defaults to production API)
# Change this only for local development with a local MCP server
# NEXT_PUBLIC_MCP_URL=https://api.pokemcp.com

# AI Gateway URL — routes Claude API calls through Cloudflare AI Gateway
# for automatic token/cost tracking, request logging, and caching.
# Format: https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_id}/anthropic
# CLOUDFLARE_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/pokemcp/anthropic
